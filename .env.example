# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/athletiq
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=athletiq
DATABASE_USER=postgres
DATABASE_PASSWORD=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback

# Garmin (unofficial API - requires auth token)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Anthropic API (for chatbot)
ANTHROPIC_API_KEY=

# AWS SNS/SMS
AWS_SNS_TOPIC_ARN=
SMS_RECIPIENT=

# AWS SES/Email
AWS_SES_FROM_EMAIL=
EMAIL_RECIPIENT=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Environment
NODE_ENV=development
